{
  "name": "@joshuarli98/md-wysiwyg",
  "version": "0.1.0",
  "description": "Markdown rendering, WYSIWYG serialization, diff, merge, and syntax highlighting for browser editors",
  "keywords": [
    "diff",
    "editor",
    "highlight",
    "markdown",
    "merge",
    "wysiwyg"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "happy-dom": "^20.8.9",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
